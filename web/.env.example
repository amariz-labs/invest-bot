# Financial Planner — environment template.
# Copy to .env.local and fill in. Never commit .env.local.

# ---------------------------------------------------------------------------
# Broker selection. One of: synthetic | alpaca | ibkr | tradier | tastytrade
# synthetic = deterministic in-memory fills; use for dev + backtests.
BROKER=synthetic

# Alpaca (paper or live). https://alpaca.markets — free paper account.
# Set ALPACA_BASE_URL to https://paper-api.alpaca.markets for paper trading.
ALPACA_KEY_ID=
ALPACA_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ---------------------------------------------------------------------------
# Market data. Polygon for real-time US equities ($29+/mo Starter tier).
# yfinance is the free historical fallback (no key needed).
POLYGON_API_KEY=

# FRED — macro releases (CPI, FOMC, NFP). Free key at fred.stlouisfed.org.
FRED_API_KEY=

# ---------------------------------------------------------------------------
# TradingView webhook receiver. See TRADINGVIEW-INTEGRATION.md §5.
# TV_WEBHOOK_SECRET must match the `X-TV-Secret` header in your TV alert URL.
# Rotate quarterly. Generate with: openssl rand -base64 32
TV_WEBHOOK_SECRET=

# Kill switch — set to "1" to return 503 to ALL incoming webhooks.
# Useful when something is misbehaving and you don't want to redeploy.
TV_WEBHOOK_KILL=0

# ---------------------------------------------------------------------------
# Webhook idempotency store (optional). If UPSTASH_REDIS_REST_URL is set the
# webhook route uses Upstash Redis for cross-instance dedup; otherwise it
# falls back to an in-memory LRU that's fine for a single-Node deployment.
# Free tier: https://upstash.com/  (REST-based, edge-runtime-safe.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
